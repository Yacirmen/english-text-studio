{
  "version": "1.0.0",
  "allowed_levels": ["A1", "A2", "B1", "B2", "C1", "C2"],
  "allowed_content_types": ["story", "dialogue", "article", "explanation", "exam_paragraph"],
  "tone_options": ["friendly", "neutral", "formal", "academic", "exam"],
  "level_rules": {
    "A1": {
      "ruleset_id": "a1_core",
      "sentence_length_avg_max": 8,
      "sentence_length_hard_max": 12,
      "new_vocab_max": 6,
      "abstraction_level": "very_low",
      "collocation_difficulty": "basic",
      "allowed_grammar": ["present_simple", "be", "have", "can", "there_is_are"],
      "allowed_content_types": ["story", "dialogue", "explanation"]
    },
    "A2": {
      "ruleset_id": "a2_expanded",
      "sentence_length_avg_max": 11,
      "sentence_length_hard_max": 16,
      "new_vocab_max": 8,
      "abstraction_level": "low",
      "collocation_difficulty": "elementary",
      "allowed_grammar": ["present_simple", "past_simple", "because", "then", "first_conditional_basic"],
      "allowed_content_types": ["story", "dialogue", "explanation"]
    },
    "B1": {
      "ruleset_id": "b1_controlled",
      "sentence_length_avg_max": 15,
      "sentence_length_hard_max": 22,
      "new_vocab_max": 10,
      "abstraction_level": "medium",
      "collocation_difficulty": "intermediate",
      "allowed_grammar": ["contrast", "cause_effect", "modals_basic", "relative_clause_basic"],
      "allowed_content_types": ["story", "dialogue", "article", "explanation"]
    },
    "B2": {
      "ruleset_id": "b2_standard",
      "sentence_length_avg_max": 20,
      "sentence_length_hard_max": 30,
      "new_vocab_max": 14,
      "abstraction_level": "medium_high",
      "collocation_difficulty": "upper_intermediate",
      "allowed_grammar": ["contrast", "cause_effect", "subordination", "relative_clause", "passive"],
      "allowed_content_types": ["article", "story", "explanation", "exam_paragraph"]
    },
    "C1": {
      "ruleset_id": "c1_analytical",
      "sentence_length_avg_max": 24,
      "sentence_length_hard_max": 34,
      "new_vocab_max": 18,
      "abstraction_level": "high",
      "collocation_difficulty": "advanced",
      "allowed_grammar": ["subordination", "concession", "nominalization", "precision_modals", "analytical_linking"],
      "allowed_content_types": ["article", "explanation", "exam_paragraph"]
    },
    "C2": {
      "ruleset_id": "c2_mastery",
      "sentence_length_avg_max": 28,
      "sentence_length_hard_max": 40,
      "new_vocab_max": 22,
      "abstraction_level": "very_high",
      "collocation_difficulty": "mastery",
      "allowed_grammar": ["advanced_subordination", "inversion", "nominalization", "rhetorical_variation", "dense_argumentation"],
      "allowed_content_types": ["article", "explanation", "exam_paragraph"]
    }
  },
  "publish_block_rules": {
    "min_level_confidence": 0.75,
    "max_repetition_score": 0.4,
    "max_similarity_score": 0.82,
    "require_all_ref_ids_to_exist": true
  }
}
